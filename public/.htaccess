# JOAT KENYA — Apache config for Truehost / cPanel static hosting.
# Copy this file to public_html/.htaccess alongside the dist/ contents.

# ─── 1. SPA fallback ──────────────────────────────────────────────────────────
# Any request that doesn't match a real file or directory gets rewritten to
# index.html so React Router's client-side routes (/privacy, /terms,
# /work-with-us, etc.) work on direct hits and refreshes.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # SEO files must be served as static files, not routed into React.
  RewriteRule ^(sitemap\.xml|robots\.txt|site\.webmanifest|llms\.txt|llms-full\.txt)$ - [L]

  # Redirect /index.html to / so direct hits land on the homepage, not the
  # in-app NotFound page. TanStack Router has no route defined for the literal
  # path /index.html so without this rule the SPA's 404 component renders.
  # 301 also consolidates SEO link equity onto the canonical /. Must run
  # before the file-exists check below, since index.html exists as a file.
  RewriteRule ^index\.html$ / [R=301,L]

  # Skip rewrite for existing files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Serve the prerendered per-route HTML (e.g. /about -> about.html). Each of
  # these carries its own <title>, canonical and meta tags, which fixes the
  # "non-canonical / duplicate-title page in sitemap" audit issues. Fail-safe:
  # a route without a matching .html simply falls through to the SPA shell.
  RewriteCond %{DOCUMENT_ROOT}/$1.html -f
  RewriteRule ^([a-z0-9-]+)/?$ $1.html [L]

  # Everything else → index.html (200 OK, not 301)
  RewriteRule ^ index.html [L]
</IfModule>

# ─── 2. Custom error pages ────────────────────────────────────────────────────
# Serve index.html for 404s so the React app renders the in-app NotFound page
# rather than Apache's default. Sends 200 — if you want a hard 404 status, use
# the alternative line below instead.
ErrorDocument 404 /index.html

# ─── 3. Compression ───────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE application/x-javascript application/xhtml+xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ─── 4. Caching ───────────────────────────────────────────────────────────────
# Vite emits content-hashed filenames for JS/CSS/images (e.g. index-Ce55rcBL.js).
# Those can be cached forever. index.html must always revalidate so updates ship.
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashed assets — cache for a year
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|jpg|jpeg|png|gif|webp|avif|svg|ico|mp4|webm)$">
    ExpiresDefault "access plus 1 year"
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML — always revalidate
  <FilesMatch "\.html$">
    ExpiresDefault "access plus 0 seconds"
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>

# ─── 5. Security headers ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "camera=(), microphone=(self), geolocation=()"

  # Content-Security-Policy — enumerates every third-party origin this site
  # actually calls: Supabase (data + storage), Web3Forms (form delivery),
  # Calendly (booking widget popup), Google Maps + Majobo Kenya (embedded
  # iframes), GA4 + Microsoft Clarity (analytics), Google Fonts. The one
  # inline <script> in index.html (the analytics bootstrap shim) is allowed
  # by exact SHA-256 hash instead of 'unsafe-inline', so injected scripts
  # still can't run even though a fixed first-party script can.
  #
  # Shipped as Report-Only: it logs violations to the browser console without
  # blocking anything. Load every page that touches a third party (home,
  # /contact, /courses/login, /courses/sign-up, /careers → apply, /products,
  # /articles, /real-estate-virtual-assistant), confirm devtools console shows
  # no CSP violations, then rename the header below from
  # "Content-Security-Policy-Report-Only" to "Content-Security-Policy" to
  # start enforcing it.
  Header always set Content-Security-Policy-Report-Only "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'sha256-7TpnKtwejAHd3uPpkuXhY7N2gQQbj4fKkUqVWPx0yLc=' https://assets.calendly.com https://www.googletagmanager.com https://www.clarity.ms; style-src 'self' 'unsafe-inline' https://assets.calendly.com https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://prkdfkkhqncxkyehokop.supabase.co https://api.web3forms.com https://www.google-analytics.com https://*.google-analytics.com https://*.analytics.google.com https://*.clarity.ms; frame-src https://calendly.com https://*.calendly.com https://www.google.com https://www.majobokenya.com; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'"
</IfModule>

# ─── 6. Force HTTPS (uncomment after SSL is provisioned on Truehost) ──────────
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>


